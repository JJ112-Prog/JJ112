public class Student {
    static int totalStudent=0;
    private String name;
    private double score;

    public Student(String name, double score) {
        this.name=name;
        this.score=score;
        totalStudent++;
    }

    public void setScore(double score){
        this.score=score;
    }

    public double getScore(){
        return score;
    }

    public void printInfo(){
        System.out.println(name+"分数是："+score);
    }

   public  Student compare(Student other){
        if(this.score>other.score){
            return this;
        }
        else if(this.score<other.score){
            return other;
        }
        else{return this;}
    }

   public static int getTotalStudent(){
        return totalStudent;
   }

    public static void main(String[] args){
        Student student1=new Student("柯洁",76);
        Student student2=new Student("二",40);
        Student student3=new Student("哈哈",55);
        Student higher = student1.compare(student2);
        System.out.println("student1 vs student2 高分者：" + higher.name);
        int a=getTotalStudent();;
        System.out.println(a);
    }

}
