public class Student {
    private String name;
    private double score;

    public Student(String name, double score) {
        this.name=name;
        this.score=score;
    }

    public void setScore(double score){
        this.score=score;
    }

    public double getScore(){
        return score;
    }

    public void printInfo(){
        System.out.println(name+"分数是："+score);
    }

   public static double compare(double score1, double score2){
        if(score1>score2){
            return score1;
        }
        else if(score1<score2){
            return score2;
        }
        else{return score1;}
    }


    public static void main(String[] args){
        Student student1=new Student("柯洁",76);
        Student student2=new Student("二",40);
        double highestScore=compare(student1.score,student2.score);
        System.out.println("比较高的分数是："+highestScore);
    }
